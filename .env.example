# Docker Compose Environment Variables
# Copy this file to .env and modify as needed

# Frontend Service
VUE_APP_API_BASE_URL=

# Backend Service (when replaced)
# DB_HOST=database
# DB_PORT=5432
# DB_NAME=yuchat
# DB_USER=admin
# DB_PASSWORD=secret

# Development
NODE_ENV=development

# Port Mappings (change if ports are in use)
FRONTEND_PORT=8080
BACKEND_PORT=5000
DEV_PORT=3000

# Docker Compose Project Name (optional)
COMPOSE_PROJECT_NAME=yuchat